# Temporary mock auth.
# Local dev reads UID/password from auth.local.json by default.
# Production/Vercel can use GOVDOC_AUTH_USERNAME + GOVDOC_AUTH_PASSWORD,
# or GOVDOC_AUTH_JSON for multiple users: {"users":[{"uid":"demo","password":"..."}]}
GOVDOC_AUTH_USERNAME=
GOVDOC_AUTH_PASSWORD=
# GOVDOC_AUTH_JSON=
# Optional file override for tests/local setups:
# GOVDOC_AUTH_FILE=/absolute/path/to/auth.local.json

# HS256 JWT signing secret. MUST be at least 32 random bytes.
# Generate with: openssl rand -hex 32
GOVDOC_SESSION_SECRET=

# LLM providers (Plans 2/3/4 use these). Plan 1 only needs them set for type checks.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Set to 1 to record real LLM responses into tests/fixtures/llm-snapshots/*.json.
# Default (unset) means MSW replays existing snapshots and fails on unknown prompts.
# RECORD_LLM=1
